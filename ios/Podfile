# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# webspace_adblock is a CocoaPod we own at rust/webspace_adblock/cocoapods/.
# Its vendored xcframework + keep_alive.c are pre-built by
# scripts/build_rust.sh apple. Auto-run the script here if the artifacts
# don't exist yet — first checkout, after `flutter clean`, etc. — so a
# fresh `pod install` doesn't fail with missing vendored paths.
def ensure_webspace_adblock_built
  pod_dir = File.expand_path('../rust/webspace_adblock/cocoapods', __dir__)
  required = [
    "#{pod_dir}/WebspaceAdblock.xcframework",
    "#{pod_dir}/libwebspace_adblock-macos.a",
    "#{pod_dir}/keep_alive.c",
  ]
  return if required.all? { |p| File.exist?(p) }
  script = File.expand_path('../scripts/build_rust.sh', __dir__)
  unless system('bash', script, 'apple')
    raise '[webspace] scripts/build_rust.sh apple failed — see output above'
  end
end

ensure_webspace_adblock_built

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  pod 'webspace_adblock', :path => '../rust/webspace_adblock/cocoapods'

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # Mark the webspace_adblock script phase always-out-of-date so
    # xcodebuild invokes scripts/build_rust.sh apple on EVERY build —
    # otherwise Xcode skips it once it's run successfully. cargo's
    # incremental compile keeps the no-op cost negligible.
    next unless target.name == 'webspace_adblock'
    target.build_phases.each do |phase|
      next unless phase.respond_to?(:name) && phase.name &&
                  phase.name.include?('Build adblock-rust artifacts')
      phase.always_out_of_date = '1'
    end
  end
end
