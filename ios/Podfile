# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# webspace_adblock is a CocoaPod we own at rust/webspace_adblock/cocoapods/.
# Its vendored xcframework + keep_alive.c are pre-built by
# scripts/build_rust.sh apple. Auto-run the script here if the artifacts
# don't exist yet — first checkout, after `flutter clean`, etc. — so a
# fresh `pod install` doesn't fail with missing vendored paths.
def ensure_webspace_adblock_built
  pod_dir = File.expand_path('../rust/webspace_adblock/cocoapods', __dir__)
  required = [
    "#{pod_dir}/WebspaceAdblock.xcframework",
    "#{pod_dir}/libwebspace_adblock-macos.a",
    "#{pod_dir}/keep_alive.c",
  ]
  return if required.all? { |p| File.exist?(p) }
  script = File.expand_path('../scripts/build_rust.sh', __dir__)
  unless system('bash', script, 'apple')
    raise '[webspace] scripts/build_rust.sh apple failed — see output above'
  end
end

ensure_webspace_adblock_built

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  pod 'webspace_adblock', :path => '../rust/webspace_adblock/cocoapods'

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # objective_c (transitive Flutter dep — pulled in via path_provider /
      # similar) ships a precompiled .framework without a dSYM. Xcode
      # archive validation then refuses to distribute with "archive did
      # not include a dSYM for the objective_c.framework ...". Emit
      # debug info inline in the binary for ALL pod targets — no
      # separate dSYM is generated and the archive validates. Apple's
      # crash symbolication is then approximate against pod code; for
      # Flutter apps where most stacks land in Dart anyway, that's an
      # acceptable trade.
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
    end

    # Mark the webspace_adblock script phase always-out-of-date so
    # xcodebuild invokes scripts/build_rust.sh apple on EVERY build —
    # otherwise Xcode skips it once it's run successfully. cargo's
    # incremental compile keeps the no-op cost negligible.
    next unless target.name == 'webspace_adblock'
    target.build_phases.each do |phase|
      next unless phase.respond_to?(:name) && phase.name &&
                  phase.name.include?('Build adblock-rust artifacts')
      phase.always_out_of_date = '1'
    end
  end

  # Migration cleanup + needed_framework injection. Two reasons we
  # touch Runner.xcodeproj's OTHER_LDFLAGS here:
  #
  # 1) Strip stale `[webspace] Build adblock-rust static lib` and
  #    `Verify ...` build phases + their -force_load / -Wl,-u flags
  #    left over from the pre-podspec architecture. CocoaPods can't
  #    auto-remove what an earlier post_install added.
  #
  # 2) Append `-Wl,-needed_framework,webspace_adblock` so Apple ld
  #    keeps webspace_adblock.framework in Runner's LC_LOAD_DYLIB
  #    even though Runner's compiled (Swift/ObjC) code has zero
  #    symbol references to it (Dart FFI dlsyms ws_* at runtime,
  #    invisible to the linker). Without this, ld's default
  #    dead_strip_dylibs drops the dependency and dyld never loads
  #    the framework, leaving dlsym(RTLD_DEFAULT, "ws_engine_new")
  #    returning null. CocoaPods' own user_target_xcconfig in the
  #    podspec silently drops OTHER_LDFLAGS overrides for keys it
  #    already manages, so we set it directly on the user project.
  #
  # Both operations are idempotent — no-op once the project is clean
  # and the flag is present.
  installer.aggregate_targets.each do |aggregate|
    next unless aggregate.name.start_with?('Pods-Runner')
    aggregate.user_project.targets.each do |runner_target|
      next unless runner_target.name == 'Runner'
      runner_target.build_phases.delete_if do |p|
        p.respond_to?(:name) && p.name && (
          p.name == '[webspace] Build adblock-rust static lib' ||
          p.name == '[webspace] Verify adblock-rust symbols linked'
        )
      end
      runner_target.build_configurations.each do |config|
        ldflags = config.build_settings['OTHER_LDFLAGS']
        ldflags = ['$(inherited)'] unless ldflags
        ldflags = [ldflags] unless ldflags.is_a?(Array)
        ldflags = ldflags.each_with_index.reject { |f, i|
          f.include?('libwebspace_adblock') ||
            f.include?('_ws_engine_new') ||
            (f == '-force_load' && ldflags[i + 1].to_s.include?('libwebspace_adblock')) ||
            (f == '-u' && ldflags[i + 1].to_s.include?('_ws_engine_new'))
        }.map(&:first)
        needed = '-Wl,-needed_framework,webspace_adblock'
        ldflags << needed unless ldflags.include?(needed)
        config.build_settings['OTHER_LDFLAGS'] = ldflags
      end
    end
    aggregate.user_project.save
  end
end
