# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Auto-build the Rust adblock-rust static library, then force-load
  # it into the Runner binary so Dart FFI's DynamicLibrary.process()
  # can resolve the symbols at runtime.
  #
  # Why force_load: the Runner has no Swift/ObjC code that references
  # our FFI symbols at compile time, so the linker dead-strips the
  # entire library by default. `-force_load <path-to-.a>` tells the
  # linker to keep every symbol regardless of references. The static
  # archive then surfaces in the .app binary's symbol table, where
  # dlsym() / DynamicLibrary.process() finds them.
  #
  # Why .a instead of XCFramework: xcframework wrapping a static
  # library doesn't have a stable Xcode-variable path to the
  # unpacked slice, which -force_load needs. Stamping .a files by
  # $(PLATFORM_NAME) (iphoneos / iphonesimulator) gives us a direct
  # path Xcode interpolates at link time.
  #
  # Idempotent: cargo skips when crate sources are unchanged.
  # Skipped silently when cargo isn't on PATH — AdblockEngine.load()
  # returns null at runtime, legacy Dart parser remains the fallback.
  installer.aggregate_targets.each do |aggregate|
    next unless aggregate.name == 'Pods-Runner'
    aggregate.user_project.targets.each do |runner_target|
      next unless runner_target.name == 'Runner'

      # 1. Build phase that produces the per-platform .a files.
      #
      # PATH note: xcodebuild starts shell phases with a constrained
      # PATH (Xcode's DEVELOPER_DIR + /usr/bin:/bin:/usr/sbin:/sbin)
      # that does NOT include ~/.cargo/bin or Homebrew prefixes. We
      # prepend the usual cargo install locations so `command -v cargo`
      # actually finds the toolchain that was installed by either
      # `rustup-init` (developer machine) or dtolnay/rust-toolchain
      # (CI). Without this prepend, the script previously skipped
      # silently, no .a was produced, and the -force_load LDFLAG
      # (step 2 below) failed with "file not found" at link time.
      phase_name = '[webspace] Build adblock-rust static lib'
      runner_target.build_phases.delete_if do |p|
        p.respond_to?(:name) && p.name == phase_name
      end
      phase = runner_target.new_shell_script_build_phase(phase_name)
      phase.shell_script = <<~BASH
        set -e
        export PATH="$HOME/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"
        if ! command -v cargo >/dev/null 2>&1; then
          echo "[webspace] cargo not found on PATH ($PATH)."
          echo "[webspace] Install Rust toolchain or the linker -force_load"
          echo "[webspace] will fail later in this build. AdblockEngine"
          echo "[webspace] would then return null; legacy Dart parser is"
          echo "[webspace] the runtime fallback."
          exit 1
        fi
        REPO_ROOT="${SRCROOT}/.."
        bash "${REPO_ROOT}/scripts/build_rust.sh" ios
      BASH
      # Declare the .a outputs so Xcode's new build system schedules
      # this phase before link AND treats the files as produced (not
      # missing inputs). Without output_paths, xcodebuild errors with
      # "Build input file cannot be found" when ld scans the
      # -force_load LDFLAG path and the file isn't in the dependency
      # graph yet, even though the script would produce it.
      phase.output_paths = [
        '$(SRCROOT)/Frameworks/libwebspace_adblock-iphoneos.a',
        '$(SRCROOT)/Frameworks/libwebspace_adblock-iphonesimulator.a',
      ]
      # Re-run when build.rs or the source changes. Cargo handles
      # finer-grained dep tracking inside; this is the coarse signal
      # to Xcode so the phase isn't always-dirty.
      phase.input_paths = [
        '$(SRCROOT)/../rust/webspace_adblock/Cargo.toml',
        '$(SRCROOT)/../rust/webspace_adblock/build.rs',
        '$(SRCROOT)/../rust/webspace_adblock/src/lib.rs',
        '$(SRCROOT)/../scripts/build_rust.sh',
      ]
      # Run before Compile Sources so the .a exists by the time
      # the linker runs.
      compile_idx = runner_target.build_phases.index { |p|
        p.respond_to?(:display_name) && p.display_name.include?('Sources')
      }
      runner_target.build_phases.move(phase, compile_idx) if compile_idx

      # 2. force-load LDFLAG keyed on $(PLATFORM_NAME). Xcode
      # substitutes the value at link time:
      #   iphoneos        — device build, arm64
      #   iphonesimulator — simulator, arm64 + x86_64 fat .a
      # The build script outputs both files into ios/Frameworks/.
      #
      # Use -Wl,-force_load,<path> (one shell token, comma-separated)
      # rather than "-force_load <path>" (one OTHER_LDFLAGS entry
      # containing a literal space). Xcode passes each OTHER_LDFLAGS
      # array element to clang as a single argv element, so the space
      # form arrived at the linker as one mashed token and ld silently
      # ignored it — the .a was never loaded, every ws_engine_* symbol
      # was missing at runtime, and dlsym(RTLD_DEFAULT, "ws_engine_new")
      # failed at ContentBlockerService startup on iOS. The -Wl, form
      # has no embedded whitespace, so clang reliably forwards it to
      # ld as `-force_load <path>` (two args).
      force_load = '-Wl,-force_load,$(SRCROOT)/Frameworks/libwebspace_adblock-$(PLATFORM_NAME).a'
      runner_target.build_configurations.each do |config|
        ldflags = config.build_settings['OTHER_LDFLAGS'] || ['$(inherited)']
        ldflags = ldflags.is_a?(Array) ? ldflags.dup : [ldflags]
        ldflags.reject! { |f| f.include?('libwebspace_adblock') }
        ldflags << force_load
        config.build_settings['OTHER_LDFLAGS'] = ldflags
      end

      # 3. Post-link verification. The history of this file is a
      # graveyard of "linker silently dropped -force_load" mistakes
      # (single-quoted LDFLAG, stale Pods/, missing .a, etc.). Each
      # produced a green build and a runtime dlsym failure visible
      # only when a real user opened the app. nm the finished binary
      # and fail the build if the canonical FFI export is missing —
      # cheaper than shipping a broken IPA.
      verify_name = '[webspace] Verify adblock-rust symbols linked'
      runner_target.build_phases.delete_if do |p|
        p.respond_to?(:name) && p.name == verify_name
      end
      verify_phase = runner_target.new_shell_script_build_phase(verify_name)
      verify_phase.shell_script = <<~BASH
        set -e
        BIN="${TARGET_BUILD_DIR}/${EXECUTABLE_PATH}"
        if [ ! -f "$BIN" ]; then
          echo "error: Runner binary not found at $BIN" >&2
          exit 1
        fi
        # -g external, -U defined-only. Mach-O C ABI prefixes with '_'.
        if ! /usr/bin/nm -gU "$BIN" 2>/dev/null | grep -q ' T _ws_engine_new$'; then
          echo "error: _ws_engine_new not exported by $BIN" >&2
          echo "error: adblock-rust .a was not force-loaded into Runner." >&2
          echo "error: check ios/Frameworks/libwebspace_adblock-${PLATFORM_NAME}.a exists" >&2
          echo "error: and OTHER_LDFLAGS contains -Wl,-force_load,... in Runner.xcodeproj." >&2
          exit 1
        fi
      BASH
      verify_phase.input_paths = []
      verify_phase.output_paths = []
      # No outputs declared → Xcode would otherwise warn and skip; opt
      # into "always run" explicitly so the check fires on every link.
      verify_phase.always_out_of_date = '1'
    end
    aggregate.user_project.save
  end
end
