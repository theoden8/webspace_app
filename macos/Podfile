platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# Mirror of ios/Podfile — see there for the rationale. The webspace_adblock
# pod's vendored .a + keep_alive.c are pre-built by scripts/build_rust.sh
# apple; this guard auto-runs it if missing so first-time / post-clean pod
# installs succeed without manual prep.
def ensure_webspace_adblock_built
  pod_dir = File.expand_path('../rust/webspace_adblock/cocoapods', __dir__)
  required = [
    "#{pod_dir}/WebspaceAdblock.xcframework",
    "#{pod_dir}/libwebspace_adblock-macos.a",
    "#{pod_dir}/keep_alive.c",
  ]
  return if required.all? { |p| File.exist?(p) }
  script = File.expand_path('../scripts/build_rust.sh', __dir__)
  unless system('bash', script, 'apple')
    raise '[webspace] scripts/build_rust.sh apple failed — see output above'
  end
end

ensure_webspace_adblock_built

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  pod 'webspace_adblock', :path => '../rust/webspace_adblock/cocoapods'

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)

    target.build_configurations.each do |config|
      # See ios/Podfile for the rationale — objective_c.framework
      # has no dSYM, so emit debug info inline in the pod binaries
      # instead of expecting separate dSYMs in the archive.
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
    end

    # See ios/Podfile — mark the webspace_adblock script phase
    # always-out-of-date so xcodebuild invokes scripts/build_rust.sh
    # apple on EVERY build.
    next unless target.name == 'webspace_adblock'
    target.build_phases.each do |phase|
      next unless phase.respond_to?(:name) && phase.name &&
                  phase.name.include?('Build adblock-rust artifacts')
      phase.always_out_of_date = '1'
    end
  end

  # See ios/Podfile — migration cleanup of stale [webspace] build
  # phases / OTHER_LDFLAGS entries, plus injection of
  # -Wl,-needed_framework,webspace_adblock so Apple ld keeps the
  # framework in Runner's LC_LOAD_DYLIB.
  installer.aggregate_targets.each do |aggregate|
    next unless aggregate.name.start_with?('Pods-Runner')
    aggregate.user_project.targets.each do |runner_target|
      next unless runner_target.name == 'Runner'
      runner_target.build_phases.delete_if do |p|
        p.respond_to?(:name) && p.name && (
          p.name == '[webspace] Build adblock-rust static lib' ||
          p.name == '[webspace] Verify adblock-rust symbols linked'
        )
      end
      runner_target.build_configurations.each do |config|
        ldflags = config.build_settings['OTHER_LDFLAGS']
        ldflags = ['$(inherited)'] unless ldflags
        ldflags = [ldflags] unless ldflags.is_a?(Array)
        ldflags = ldflags.each_with_index.reject { |f, i|
          f.include?('libwebspace_adblock') ||
            f.include?('_ws_engine_new') ||
            (f == '-force_load' && ldflags[i + 1].to_s.include?('libwebspace_adblock')) ||
            (f == '-u' && ldflags[i + 1].to_s.include?('_ws_engine_new'))
        }.map(&:first)
        needed = '-Wl,-needed_framework,webspace_adblock'
        ldflags << needed unless ldflags.include?(needed)
        config.build_settings['OTHER_LDFLAGS'] = ldflags
        # See ios/Podfile — archive validation runs against Runner's
        # own setting, not just the pods'.
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
      end
    end
    aggregate.user_project.save
  end
end
