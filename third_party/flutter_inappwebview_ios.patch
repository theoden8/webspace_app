+           anyEqual(viewId, webViewId) {
+            return webView
+        }
+        for subview in view.subviews {
+            if let found = findInAppWebViewByIdRecursive(subview, webViewId) {
+                return found
+            }
+        }
+        return nil
+    }
+
+    // [WebSpace fork patch]
+    // Compare two `Any` ids — they may be Int / Int64 / NSNumber on
+    // the numeric path (Flutter standard codec decodes ints to
+    // NSNumber, while `InAppWebView.id` is a typed Int64). Bridging
+    // through NSNumber.isEqual handles every numeric pair without
+    // caring which exact Swift type each side has.
+    private static func anyEqual(_ a: Any, _ b: Any) -> Bool {
+        if let an = a as? NSNumber, let bn = b as? NSNumber {
+            return an.isEqual(bn)
+        }
+        if let as_ = a as? String, let bs = b as? String { return as_ == bs }
+        return false
+    }
