@@ -0,0 +1,51 @@
+//
+// WebSpaceProfile.swift
+//
+// [WebSpace fork patch] — see third_party/PATCHES.md in the WebSpace repo
+//
+// Deterministic UUID derivation for per-site WKWebsiteDataStore
+// identifiers. Apple's `WKWebsiteDataStore(forIdentifier:)` requires a
+// UUID; our app uses opaque siteId strings. We need:
+//
+//   - **Stability across launches.** Restarting the app must yield the
+//     same UUID for the same siteId so the on-disk data store is
+//     re-attached, not re-created.
+//   - **Stability across builds.** Reinstalling the app shouldn't lose
+//     a user's logged-in session.
+//   - **No network identity leak.** The UUID is derived from the
+//     siteId only; nothing identifying about the device.
+//
+// Implementation: SHA-256 over the UTF-8 bytes of the siteId, take the
+// first 16 bytes, format as a UUID. Not RFC 4122 v5 (we don't bother
+// setting version/variant bits — Apple's API doesn't validate them and
+// every value we produce is a valid UUID byte pattern). Collision
+// probability is the same as any 128-bit hash digest: cryptographically
+// negligible for the number of sites a user can plausibly create.
+//
+// The plugin's `preWKWebViewConfiguration` and the app's
+// `WebSpaceProfilePlugin.swift` both call this so the UUID stays
+// consistent across the bind / delete / enumerate path.
+
+import CommonCrypto
+import Foundation
+
+@available(iOS 17.0, macOS 14.0, *)
+public enum WebSpaceProfile {
+    /// Derive the canonical `WKWebsiteDataStore` identifier for a
+    /// site profile name (typically `"ws-<siteId>"`, but any stable
+    /// string works).
+    public static func uuid(for profileName: String) -> UUID {
+        let data = Data(profileName.utf8)
+        var digest = [UInt8](repeating: 0, count: Int(CC_SHA256_DIGEST_LENGTH))
+        data.withUnsafeBytes { bytes in
+            _ = CC_SHA256(bytes.baseAddress, CC_LONG(data.count), &digest)
+        }
+        let bytes = (
+            digest[0], digest[1], digest[2], digest[3],
+            digest[4], digest[5], digest[6], digest[7],
+            digest[8], digest[9], digest[10], digest[11],
+            digest[12], digest[13], digest[14], digest[15]
+        )
+        return UUID(uuid: bytes)
+    }
+}
