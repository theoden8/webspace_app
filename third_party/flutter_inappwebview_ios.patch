+    // for an InAppWebView whose `id` matches [webViewId]. Same
+    // enumeration pattern as the Android Java side.
+    private static func findInAppWebViewById(_ webViewId: Any) -> InAppWebView? {
+        // Sweep through every scene's windows (iOS 13+ supports
+        // multiple windows per app via UIWindowScene).
+        for scene in UIApplication.shared.connectedScenes {
+            guard let windowScene = scene as? UIWindowScene else { continue }
+            for window in windowScene.windows {
+                if let found = findInAppWebViewByIdRecursive(window, webViewId) {
+                    return found
+                }
+            }
+        }
+        return nil
+    }
