+    //   - InAppWebView with that id isn't in the live window hierarchy,
+    //   - WKWebsiteDataStore identifiers aren't supported (iOS <17).
+    // Stock callers (no webViewController) hit the default store
+    // path identically to upstream.
+    static func httpCookieStoreForWebView(_ webViewId: Any?) -> WKHTTPCookieStore {
+        if let webViewId = webViewId,
+           let webView = findInAppWebViewById(webViewId) {
+            return webView.configuration.websiteDataStore.httpCookieStore
