+    private static func anyEqual(_ a: Any, _ b: Any) -> Bool {
+        if let an = a as? NSNumber, let bn = b as? NSNumber {
+            return an.isEqual(bn)
+        }
+        if let as_ = a as? String, let bs = b as? String { return as_ == bs }
+        return false
+    }
     
