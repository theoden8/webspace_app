@@ -0,0 +1,36 @@
+//
+// WebSpaceProfile.swift
+//
+// [WebSpace fork patch] — see third_party/PATCHES.md in the WebSpace repo
+//
+// Sister copy of the iOS fork's WebSpaceProfile helper. The two
+// platform packages don't share a Swift module so the helper is
+// duplicated; the byte-level definition stays identical so the
+// derived UUID for a given profile name is the same on both
+// platforms (a macOS user signing into a site, then logging into
+// the same iCloud sync on iOS, would otherwise have to re-attach to
+// a different on-disk store).
+//
+// Keep the SHA-256 logic byte-identical to
+// third_party/flutter_inappwebview_ios/ios/Classes/InAppWebView/WebSpaceProfile.swift.
+
+import CommonCrypto
+import Foundation
+
+@available(macOS 14.0, *)
+public enum WebSpaceProfile {
+    public static func uuid(for profileName: String) -> UUID {
+        let data = Data(profileName.utf8)
+        var digest = [UInt8](repeating: 0, count: Int(CC_SHA256_DIGEST_LENGTH))
+        data.withUnsafeBytes { bytes in
+            _ = CC_SHA256(bytes.baseAddress, CC_LONG(data.count), &digest)
+        }
+        let bytes = (
+            digest[0], digest[1], digest[2], digest[3],
+            digest[4], digest[5], digest[6], digest[7],
+            digest[8], digest[9], digest[10], digest[11],
+            digest[12], digest[13], digest[14], digest[15]
+        )
+        return UUID(uuid: bytes)
+    }
+}
