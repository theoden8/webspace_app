+  // [WebSpace fork patch] — see third_party/PATCHES.md
+  // Resolve the per-profile CookieManager for the WebView identified
+  // by [webViewId] (typically the platform-view int passed from Dart
+  // as the `webViewId` arg). When the WebView is bound to a non-
+  // default `androidx.webkit.Profile`, returns that profile's
+  // `CookieManager` so subsequent reads/writes target the per-site
+  // cookie jar instead of the global default. Falls back to the
+  // global manager when:
+  //   - webViewId is null (caller didn't scope the op)
+  //   - MULTI_PROFILE feature unsupported (System WebView <110)
+  //   - InAppWebView with that id isn't in the live view tree
+  //   - bound profile is the default profile (or unavailable)
+  // The fallback path is byte-identical to stock upstream behavior,
+  // so unscoped callers (DevTools cookie inspector during legacy
+  // mode, settings-import path, etc.) keep working unchanged.
+  private @Nullable CookieManager getCookieManagerForWebView(@Nullable Object webViewId) {
+    if (webViewId == null || plugin == null || plugin.activity == null) {
+      return getCookieManager();
+    }
+    if (!WebViewFeature.isFeatureSupported(WebViewFeature.MULTI_PROFILE)) {
+      return getCookieManager();
+    }
+    InAppWebView webView = findInAppWebViewById(
+        plugin.activity.getWindow().getDecorView().getRootView(), webViewId);
+    if (webView == null) return getCookieManager();
+    Profile profile;
+    try {
+      profile = WebViewCompat.getProfile(webView);
+    } catch (Throwable t) {
+      return getCookieManager();
+    }
+    if (profile == null) return getCookieManager();
+    if (Profile.DEFAULT_PROFILE_NAME.equals(profile.getName())) {
+      return getCookieManager();
+    }
+    return profile.getCookieManager();
+  }
+
+  // [WebSpace fork patch]
+  // Recursive view-tree walk locating the InAppWebView whose `id`
+  // matches [webViewId]. Same enumeration pattern WebSpaceProfilePlugin
+  // and WebInterceptPlugin use; sub-millisecond on a typical tree.
+  private static @Nullable InAppWebView findInAppWebViewById(View view, Object webViewId) {
+    if (view instanceof InAppWebView) {
+      InAppWebView wv = (InAppWebView) view;
+      if (webViewId.equals(wv.id)) return wv;
+    }
+    if (view instanceof ViewGroup) {
+      ViewGroup vg = (ViewGroup) view;
+      for (int i = 0; i < vg.getChildCount(); i++) {
+        InAppWebView found = findInAppWebViewById(vg.getChildAt(i), webViewId);
+        if (found != null) return found;
+      }
+    }
+    return null;
+  }
