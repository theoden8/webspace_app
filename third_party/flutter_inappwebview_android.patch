   @SuppressLint("RestrictedApi")
   public void prepare() {
+    // [WebSpace fork patch] — see third_party/PATCHES.md in the WebSpace repo
+    // The Profile API requires WebViewCompat.setProfile to run BEFORE any
+    // session-bound operation on the WebView. Stock prepare() calls
+    // addJavascriptInterface, addDocumentStartJavaScript, and
+    // CookieManager.setAcceptThirdPartyCookies a few lines below — each
+    // of which locks the WebView to whichever profile is current
+    // (default), making the post-construction bind path the user-app
+    // tried (`ProfileNative.bindProfileToWebView` walking the view tree
+    // from `onWebViewCreated`) silently no-op with IllegalStateException.
+    //
+    // Doing the bind here, before anything else in prepare(), partitions
+    // cookies / localStorage / IDB / ServiceWorkers / HTTP cache for the
+    // rest of the WebView's lifetime.
+    if (customSettings.webspaceProfile != null
+        && WebViewFeature.isFeatureSupported(WebViewFeature.MULTI_PROFILE)) {
+      try {
+        ProfileStore.getInstance().getOrCreateProfile(customSettings.webspaceProfile);
+        WebViewCompat.setProfile(this, customSettings.webspaceProfile);
+      } catch (Throwable t) {
+        android.util.Log.w(LOG_TAG,
+            "WebSpace fork: setProfile(" + customSettings.webspaceProfile + ") failed: " + t);
+      }
+    }
