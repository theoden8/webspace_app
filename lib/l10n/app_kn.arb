  "siteSettingsWindowHeight": "ಪೆಟ್ಟಿಗೆಯ ಎತ್ತರ",
  "siteSettingsWindowSizeHelper": "ಪುಟವನ್ನು ಕೇಂದ್ರೀಕೃತ ಪೆಟ್ಟಿಗೆಯಲ್ಲಿ ತೋರಿಸುತ್ತದೆ ಮತ್ತು ಪರದೆಯ ಗಾತ್ರವನ್ನು ಸ್ಥಿರ ಗ್ರಿಡ್‌ಗೆ ಕೆಳಕ್ಕೆ ಸುತ್ತುತ್ತದೆ (Tor Browser ನಂತೆ) ಇದರಿಂದ ಹಲವು ಸಾಧನಗಳು ಒಂದೇ ಗಾತ್ರವನ್ನು ವರದಿ ಮಾಡುತ್ತವೆ, ಇದು ಪರದೆ-ಗಾತ್ರದ ಫಿಂಗರ್‌ಪ್ರಿಂಟಿಂಗ್ ಅನ್ನು ಕಡಿಮೆ ಮಾಡುತ್ತದೆ.",
  "siteSettingsWindowSizeRequiresProtection": "ಕಸ್ಟಮ್ ಬಾಕ್ಸ್ ಗಾತ್ರವನ್ನು ಹೊಂದಿಸಲು ಲೆಟರ್‌ಬಾಕ್ಸ್ ವಿಂಡೋ ಆನ್ ಮಾಡಿ.",
  "siteSettingsLetterboxTitle": "ಲೆಟರ್‌ಬಾಕ್ಸ್ ವಿಂಡೋ",
  "siteSettingsLetterboxSubtitle": "ಪರದೆ-ಗಾತ್ರದ ಫಿಂಗರ್‌ಪ್ರಿಂಟಿಂಗ್ ಕಡಿಮೆ ಮಾಡಲು ಪುಟವನ್ನು ಕೇಂದ್ರೀಕೃತ, ಗಾತ್ರ-ಗುಂಪುಗೊಳಿಸಿದ ಪೆಟ್ಟಿಗೆಯಲ್ಲಿ ತೋರಿಸಿ (Tor Browser ನಂತೆ)",
  "siteSettingsLetterboxAutoHint": "auto",
  "appSettingsOutboundProxyHint": "ಅಪ್ಲಿಕೇಶನ್ ಮಾಡುವ ಪ್ರತಿ Dart-ಭಾಗದ ನೆಟ್‌ವರ್ಕ್ ಕರೆಗೆ ಅನ್ವಯಿಸಲ್ಪಡುವ Proxy — DNS ನಿರ್ಬಂಧಪಟ್ಟಿ ಡೌನ್‌ಲೋಡ್‌ಗಳು, ClearURLs ನಿಯಮಗಳು, ವಿಷಯ ನಿರ್ಬಂಧಕ ನಿಯಮಗಳು, LocalCDN ಕ್ಯಾಟಲಾಗ್, ಫೇವಿಕಾನ್ ಹುಡುಕಾಟಗಳು (DuckDuckGo / Google / ಸೈಟ್ ಪಾರ್ಸಿಂಗ್) ಮತ್ತು ಸ್ಥಳ ಆಯ್ಕೆಗಾರದಲ್ಲಿ OSM ಮ್ಯಾಪ್ ಟೈಲ್‌ಗಳು.\n\nಪ್ರತಿ-ಸೈಟ್ proxy ಆದ್ಯತೆ: Proxy ಪ್ರಕಾರ DEFAULT ಆಗಿರುವ ಸೈಟ್ ಈ proxy ಅನ್ನು ಆನುವಂಶಿಕವಾಗಿ ಪಡೆಯುತ್ತದೆ; ಸ್ಪಷ್ಟವಾದ ಪ್ರತಿ-ಸೈಟ್ HTTP/HTTPS/SOCKS5 ಅತಿಕ್ರಮಣಗಳು ಗೆಲ್ಲುತ್ತವೆ.\n\nDart-ಭಾಗದ HTTP ಮೂಲಕ SOCKS5 ಅನ್ನು ಸುರಂಗ ಮಾಡಲಾಗುವುದಿಲ್ಲ. SOCKS5 ಆಯ್ಕೆ ಮಾಡಿದಾಗ, ಅಪ್ಲಿಕೇಶನ್-ಮಟ್ಟದ ಮನವಿಗಳು ನೇರ ಫಾಲ್‌ಬ್ಯಾಕ್ ಮೂಲಕ ಸಾಧನದ IP ಸೋರಿಕೆ ಮಾಡುವ ಬದಲು ವಿಫಲ-ಮುಚ್ಚಿ ನೀತಿ ಅನುಸರಿಸುತ್ತವೆ. Android/iOS ನಲ್ಲಿ ವೆಬ್‌ವ್ಯೂ ನ್ಯಾವಿಗೇಶನ್ ಇನ್ನೂ ಸಾಮಾನ್ಯವಾಗಿ SOCKS5 ಬಳಸುತ್ತದೆ.",
  "appSettingsLocationPickerHint": "ಪ್ರತಿ-ಸೈಟ್ ಸ್ಥಳ ಆಯ್ಕೆಗಾರ ಬಳಸುವ ಟೈಲ್ URL. ಬಳಕೆದಾರರು ಆಯ್ಕೆಗಾರದಲ್ಲಿ \"ನಕ್ಷೆ ಲೋಡ್ ಮಾಡಿ\" ಟ್ಯಾಪ್ ಮಾಡದ ಹೊರತು ಯಾವುದೇ ಟೈಲ್‌ಗಳನ್ನು ಪಡೆಯಲಾಗುವುದಿಲ್ಲ — ಅಪ್ಲಿಕೇಶನ್ ಈ ಪೂರೈಕೆದಾರರಿಗೆ ಎಂದಿಗೂ ಹಿನ್ನೆಲೆ ವಿನಂತಿಗಳನ್ನು ಮಾಡುವುದಿಲ್ಲ. z, x, ಮತ್ತು y ಸ್ಥಳಪೂರಕಗಳನ್ನು OSM ಟೈಲ್ ನಿರ್ದೇಶಾಂಕಗಳೊಂದಿಗೆ ಬದಲಾಯಿಸಲಾಗುತ್ತದೆ. OpenStreetMap ಡೀಫಾಲ್ಟ್; ಯಾವುದೇ OSM-ಹೊಂದಾಣಿಕೆಯ ಪೂರೈಕೆದಾರರಿಗೆ (MapTiler, CartoDB, ಸ್ವ-ಆತಿಥ್ಯ ಸರ್ವರ್, ಇತ್ಯಾದಿ) ಬದಲಾಯಿಸಬಹುದು.",
  "appSettingsTimezonePolygonsHint": "ಪ್ರತಿ-ಸೈಟ್ ಸೆಟ್ಟಿಂಗ್ಸ್‌ನಲ್ಲಿ \"ಆಯ್ದ ಸ್ಥಳದಿಂದ\" ಸಮಯವಲಯ ಆಯ್ಕೆ ನೀಡಲು IANA ಸಮಯವಲಯ ಗಡಿಗಳ GeoJSON ಡೇಟಾಸೆಟ್ (~10–60 MB) ಡೌನ್‌ಲೋಡ್ ಮಾಡುತ್ತದೆ, ಇದು ನಿಮ್ಮ ಸ್ಪೂಫ್ ಮಾಡಿದ ನಿರ್ದೇಶಾಂಕಗಳ IANA ವಲಯವನ್ನು ಸ್ವಯಂ-ಸಂಕಲ್ಪಿಸುತ್ತದೆ. ಬೇಡಿಕೆಯ ಮೇರೆಗೆ ಮಾತ್ರ ಪಡೆಯಲಾಗುತ್ತದೆ (ಈ ಬಟನ್); ನೀವು ತೆರವುಗೊಳಿಸುವವರೆಗೆ ಅಪ್ಲಿಕೇಶನ್ ಖಾಸಗಿ ಶೇಖರಣೆಯಲ್ಲಿ ಇಡಲಾಗುತ್ತದೆ. ಡೀಫಾಲ್ಟ್ ಮೂಲ: timezone-boundary-builder GitHub ಬಿಡುಗಡೆಗಳು. ಅಳಿಸಲು \"ತೆರವುಗೊಳಿಸಿ\" ಟ್ಯಾಪ್ ಮಾಡಿ.",
  "appSettingsTrustedCertificatesHint": "ಯಾವುದೇ ಸೈಟ್ ಸ್ವಯಂ-ಸಹಿ ಮಾಡಿದ ಅಥವಾ ಅನ್ಯಥಾ-ಅವಿಶ್ವಾಸಾರ್ಹ TLS ಪ್ರಮಾಣಪತ್ರ ಪ್ರಸ್ತುತಪಡಿಸಿ ನೀವು ಪ್ರಾಂಪ್ಟ್‌ನಲ್ಲಿ \"ಈ ಸೈಟ್ ಅನ್ನು ವಿಶ್ವಾಸಿಸಿ\" ಟ್ಯಾಪ್ ಮಾಡಿದಾಗ, ಫಿಂಗರ್‌ಪ್ರಿಂಟ್ ಇಲ್ಲಿ ಪಿನ್ ಮಾಡಲಾಗುತ್ತದೆ. ಅದೇ ಪ್ರಮಾಣಪತ್ರ ನೀಡಿಸಿದರೆ ಆ ಹೋಸ್ಟ್‌ಗೆ ಭವಿಷ್ಯದ ಭೇಟಿಗಳು ಮೌನವಾಗಿ ಲೋಡ್ ಆಗುತ್ತವೆ. ಯಾವುದೇ ಪಿನ್ ಅನ್ನು ಪರೀಕ್ಷಿಸಲು ಮತ್ತು ರದ್ದುಗೊಳಿಸಲು ಈ ಪರದೆ ತೆರೆಯಿರಿ.",
  "appSettingsClearUrlsHint": "ವೆಬ್‌ಸೈಟ್‌ಗಳು ಬಳಸುವ ಟ್ರ್ಯಾಕಿಂಗ್ ಪ್ಯಾರಾಮೀಟರ್‌ಗಳ ಪಟ್ಟಿಯನ್ನು ಡೌನ್‌ಲೋಡ್ ಮಾಡುತ್ತದೆ (ಉದಾ. utm_source, fbclid, ಇತ್ಯಾದಿ). ಪ್ರತಿ-ಸೈಟ್ ಸಕ್ರಿಯಗೊಳಿಸಿದಾಗ, ನಿಮ್ಮ ಗೌಪ್ಯತೆ ರಕ್ಷಿಸಲು ಈ ಪ್ಯಾರಾಮೀಟರ್‌ಗಳನ್ನು URL‌ಗಳಿಂದ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ತೆಗೆದುಹಾಕಲಾಗುತ್ತದೆ.",
  "appSettingsDnsBlocklistHint": "ತಿಳಿದ ಜಾಹೀರಾತು, ಟ್ರ್ಯಾಕಿಂಗ್ ಮತ್ತು ಮಾಲ್‌ವೇರ್ ಡೊಮೇನ್‌ಗಳನ್ನು ನಿರ್ಬಂಧಿಸಲು Hagezi ನಿರ್ಬಂಧಪಟ್ಟಿಯನ್ನು ಡೌನ್‌ಲೋಡ್ ಮಾಡುತ್ತದೆ. ಲಘುವಿನಿಂದ ಅಂತಿಮದವರೆಗೆ ತೀವ್ರತೆ ಮಟ್ಟ ಆಯ್ಕೆ ಮಾಡಿ. ಹೆಚ್ಚಿನ ಮಟ್ಟಗಳು ಹೆಚ್ಚು ಡೊಮೇನ್‌ಗಳನ್ನು ನಿರ್ಬಂಧಿಸುತ್ತವೆ ಆದರೆ ಕೆಲವು ಸೈಟ್‌ಗಳನ್ನು ಮುರಿಯಬಹುದು. ಒಮ್ಮೆ ಡೌನ್‌ಲೋಡ್ ಮಾಡಿದ ನಂತರ, ಪ್ರತಿ ಸೈಟ್‌ನ ಸೆಟ್ಟಿಂಗ್ಸ್‌ನಲ್ಲಿ ಪ್ರತಿ-ಸೈಟ್ ಸಕ್ರಿಯ ಅಥವಾ ನಿಷ್ಕ್ರಿಯ ಮಾಡಿ.",
  "appSettingsLocalCdnHint": "ಮೂರನೇ-ಪಕ್ಷದ CDN ಸರ್ವರ್‌ಗಳಿಂದ (Google, Cloudflare, jsDelivr ನಂತಹ) ಪಡೆಯುವ ಬದಲು ಸ್ಥಳೀಯವಾಗಿ ನೀಡಲು ಸಾಮಾನ್ಯ JavaScript ಗ್ರಂಥಾಲಯಗಳು, ಫಾಂಟ್‌ಗಳು ಮತ್ತು CSS ಚೌಕಟ್ಟುಗಳನ್ನು ಡೌನ್‌ಲೋಡ್ ಮಾಡುತ್ತದೆ. ಇದು CDN ಪೂರೈಕೆದಾರರು ವಿವಿಧ ವೆಬ್‌ಸೈಟ್‌ಗಳಾದ್ಯಂತ ನಿಮ್ಮ ಬ್ರೌಸಿಂಗ್ ಟ್ರ್ಯಾಕ್ ಮಾಡುವುದನ್ನು ತಡೆಯುತ್ತದೆ.",
  "appSettingsContentBlockerHint": "EasyList ನಂತಹ ಫಿಲ್ಟರ್ ಪಟ್ಟಿಗಳನ್ನು ಬಳಸಿ ಜಾಹೀರಾತುಗಳು, ಟ್ರ್ಯಾಕರ್‌ಗಳು ಮತ್ತು ಅನಗತ್ಯ ಪುಟ ಅಂಶಗಳನ್ನು ನಿರ್ಬಂಧಿಸುತ್ತದೆ. ಡೊಮೇನ್-ಮಟ್ಟದ ನಿರ್ಬಂಧ, ಪುಟ ಅಂಶಗಳನ್ನು ಮರೆಮಾಡಲು CSS ಕಾಸ್ಮೆಟಿಕ್ ಫಿಲ್ಟರ್‌ಗಳು ಮತ್ತು ಪಠ್ಯ-ಆಧಾರಿತ ಮರೆಮಾಡುವ ನಿಯಮಗಳನ್ನು ಬೆಂಬಲಿಸುತ್ತದೆ. ಕೆಳಗೆ ಪ್ರತ್ಯೇಕ ಫಿಲ್ಟರ್ ಪಟ್ಟಿಗಳನ್ನು ಸಕ್ರಿಯ ಅಥವಾ ನಿಷ್ಕ್ರಿಯ ಮಾಡಿ, ಮತ್ತು ಪ್ರತಿ ಸೈಟ್‌ನ ಸೆಟ್ಟಿಂಗ್ಸ್‌ನಲ್ಲಿ ಪ್ರತಿ-ಸೈಟ್ ವಿಷಯ ನಿರ್ಬಂಧ ಆನ್/ಆಫ್ ಮಾಡಿ.",
  "appSettingsTabMaxWidth": "ಟ್ಯಾಬ್ ಅಗಲ ಮಿತಿ",
  "appSettingsTabMaxWidthSubtitle": "ಉದ್ದದ ಹೆಸರುಗಳು ಸಾಂದ್ರವಾಗಿರಲು ಪ್ರತಿ ಟ್ಯಾಬ್ ಎಷ್ಟು ಅಗಲವಾಗಬಹುದು ಎಂಬುದನ್ನು ಮಿತಿಗೊಳಿಸಿ",
