  "homeShortcutDisable": "ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ",
  "homeShortcutPickTitle": "ಶಾರ್ಟ್‌ಕಟ್ ಅನ್ನು ಇದಕ್ಕೆ ಸೂಚಿಸಿ",
  "appSettingsLanguageTitle": "ಅಪ್ಲಿಕೇಶನ್ ಭಾಷೆ",
  "appSettingsLanguageSystem": "ಸಿಸ್ಟಮ್ ಡೀಫಾಲ್ಟ್",
